# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=carcare.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://carcare.example.com
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0

# PostgreSQL
POSTGRES_DB=car_care
POSTGRES_USER=car_care
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Telegram
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_WEBAPP_URL=https://carcare.example.com/app/
TELEGRAM_WEBAPP_AUTH_MAX_AGE_SECONDS=86400

# Runtime
HTTP_PORT=80
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
NOTIFICATION_WORKER_BATCH_SIZE=100
NOTIFICATION_WORKER_SLEEP_SECONDS=60

# AI Assistant
AI_ASSISTANT_ENABLED=false
AI_ASSISTANT_PROVIDER=openai-compatible
AI_ASSISTANT_API_KEY=replace-with-ai-provider-key
AI_ASSISTANT_BASE_URL=https://api.openai.com/v1
AI_ASSISTANT_MODEL=gpt-4o-mini
AI_ASSISTANT_TIMEOUT_SECONDS=30
AI_ASSISTANT_MAX_CONTEXT_RECORDS=5
