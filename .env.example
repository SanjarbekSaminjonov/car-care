# Bu fayl environment namunalari uchun.
# Local entrypointlar `.env` ni avtomatik o'qimaydi; process env ustuvor.
# Production muhitda env'lar tashqi orchestrator orqali berilishi kerak.

# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=car_care
POSTGRES_USER=car_care
POSTGRES_PASSWORD=car_care
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Docker Compose ichida `POSTGRES_HOST=db` avtomatik beriladi.

# Telegram
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_WEBAPP_URL=https://your-domain.example/app/
TELEGRAM_WEBAPP_AUTH_MAX_AGE_SECONDS=86400

# AI Assistant
AI_ASSISTANT_ENABLED=false
AI_ASSISTANT_PROVIDER=openai-compatible
AI_ASSISTANT_API_KEY=replace-with-ai-provider-key
AI_ASSISTANT_BASE_URL=https://api.openai.com/v1
AI_ASSISTANT_MODEL=gpt-4o-mini
AI_ASSISTANT_TIMEOUT_SECONDS=30
AI_ASSISTANT_MAX_CONTEXT_RECORDS=5

# Runtime
HTTP_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
NOTIFICATION_WORKER_BATCH_SIZE=100
NOTIFICATION_WORKER_SLEEP_SECONDS=60
