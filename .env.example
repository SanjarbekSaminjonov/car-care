# Bu fayl environment namunalari uchun.
# Local entrypointlar `.env` ni avtomatik o'qimaydi; process env ustuvor.
# Production muhitda env'lar tashqi orchestrator orqali berilishi kerak.

# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=car_care
POSTGRES_USER=car_care
POSTGRES_PASSWORD=car_care
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
